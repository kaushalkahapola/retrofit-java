
# ============================================================================
# LLM PROVIDER CONFIGURATION
# ============================================================================
# Choose your LLM provider: openai, azure, groq, google, custom

# Provider: OpenAI (Default)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk_your_api_key_here

# Provider: Azure OpenAI
# Uncomment and configure these for Azure OpenAI
# LLM_PROVIDER=azure
# LLM_MODEL=gpt-4
# AZURE_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_CHAT_DEPLOYMENT=your-deployment-name
# AZURE_CHAT_VERSION=2024-02-01
# AZURE_OPENAI_API_KEY=your_azure_api_key

# Provider: Groq (Fast & Cheap)
# Uncomment and configure these for Groq
# LLM_PROVIDER=groq
# LLM_MODEL=openai/gpt-oss-120b
# GROQ_API_KEY=

# Provider: Google Gemini
# Uncomment and configure these for Google Gemini
# LLM_PROVIDER=google
# LLM_MODEL=gemini-2.0-flash
# GOOGLE_API_KEY=your_google_api_key

# Provider: OpenAI-compatible (e.g., local LLM server, Ollama, etc.)
# Uncomment and configure these for OpenAI-compatible endpoints
# LLM_PROVIDER=openai
# OPENAI_BASE_URL=http://localhost:8000  # e.g., Ollama server
# OPENAI_API_KEY=ollama  # or any dummy key for local servers

# ============================================================================
# MCP SERVER CONFIGURATION (if using local analysis engine)
# ============================================================================
# MCP_SERVER_URL=http://localhost:8080/mcp/sse

# ============================================================================
# OTHER CONFIGURATIONS
# ============================================================================
# Add any other environment variables your setup requires

# CEREBRAS
# LLM_PROVIDER=cerebras
# LLM_MODEL=gpt-oss-120b
# CEREBRAS_API_KEY=